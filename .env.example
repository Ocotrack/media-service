# ============================================================
# Storage: S3-Compatible Provider
# ============================================================
# Works with: AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces, etc.
#
# For AWS S3:
#   Leave AWS_ENDPOINT_URL empty or unset.
#
# For MinIO / Cloudflare R2 / other S3-compatible providers:
#   Set AWS_ENDPOINT_URL to your provider's endpoint.
#
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=media
AWS_REGION=us-east-1

# Optional: Custom endpoint for non-AWS S3 providers (MinIO, R2, etc.)
# AWS_ENDPOINT_URL=http://localhost:9000

# Optional: Public CDN URL to replace the internal endpoint in presigned URLs.
# Set this if your storage is behind a CDN or public domain.
# AWS_PUBLIC_URL=https://cdn.yourdomain.com

# ============================================================
# API Security
# ============================================================
# Comma-separated list of "key:client_id" pairs.
# Example: "secret123:app_backend,anothersecret:mobile_app"
API_KEYS=your_api_key_here:default_client

# ============================================================
# Media Processing
# ============================================================
# Max side (px) before resizing images. Default: 1280
IMAGE_MAX_DIMENSION=1280

# WebP image quality (1-100). Lower = smaller file. Default: 75
IMAGE_QUALITY=75

# Comma-separated list of allowed document file extensions (no dots).
# Default: pdf,xlsx,xls,docx,txt,xml
ALLOWED_EXTENSIONS=pdf,xlsx,xls,docx,txt,xml

# ============================================================
# Async Video Processing
# ============================================================
# Max number of parallel FFmpeg processes.
# Recommended: 1-2 for small servers, higher for dedicated media servers.
MAX_CONCURRENT_JOBS=2

# ============================================================
# Presigned URL Configuration
# ============================================================
# How long (seconds) generated URLs remain valid. Default: 3600 (1 hour)
MEDIA_URL_TTL_SECONDS=3600

# ============================================================
# Cache-Control Headers
# ============================================================
# Injected into S3 object metadata at upload time.
# UUIDs are content-addressed (immutable by design), so long TTLs are safe.
# UPLOAD_CACHE_CONTROL=public, max-age=31536000, immutable

# Sent in GET /media/download HTTP responses.
# 'private' → Cloudflare skips CDN caching (auth-gated endpoint). Browser still caches.
# 'public'  → Cloudflare and browser both cache (only for fully public, non-sensitive files).
# DOWNLOAD_CACHE_CONTROL=private, max-age=31536000, immutable

# Controls how the browser handles the downloaded file.
# 'inline'     → browser renders images and PDFs in-tab.
# 'attachment' → browser always forces a file download dialog.
# DOWNLOAD_CONTENT_DISPOSITION=inline

# ============================================================
# Service Port
# ============================================================
PORT=8002
