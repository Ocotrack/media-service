# ========================================
# MinIO Credentials
# ========================================
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Casamago1.
MINIO_BUCKET=media
MINIO_REGION=us-east-1

# ========================================
# Internal Configuration (Docker to Docker)
# ========================================
# Used by the app to upload/delete files and validate buckets
# This is INTERNAL communication within Docker, does NOT use SSL
MINIO_ENDPOINT_INTERNAL=minio:9003
MINIO_USE_SSL=false

# ========================================
# Public Configuration (For signing URLs)
# ========================================
# Used EXCLUSIVELY to generate signed URLs
# Must match EXACTLY the public domain of Server 1
# IMPORTANT: Do NOT include port because 443 (HTTPS) is default
MINIO_ENDPOINT_PUBLIC=cdn.meximova.com
MINIO_PUBLIC_USE_SSL=true

# ========================================
# Media Service Configuration
# ========================================
MEDIA_URL_TTL_SECONDS=3600
API_KEYS=your_api_key_here
PORT=8002
ENV=production
